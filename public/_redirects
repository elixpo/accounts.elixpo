# Cloudflare Pages _redirects file.
#
# Format: <source> <destination> <status>
# Status 200 = rewrite (URL stays the same, content from destination).
# Status 301/302 = redirect (URL changes).
#
# Processed by Cloudflare Pages at the edge BEFORE the Next.js function
# runs — useful for paths Next.js can't handle natively (e.g. dot-
# prefixed segments like /.well-known/).

# Microsoft Entra publisher-domain verification.
# Microsoft Entra fetches this exact URL; we proxy to a static JSON file
# in public/ root so the request never enters Next.js at all.
/.well-known/microsoft-identity-association.json  /microsoft-identity-association.json  200
