# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://accounts.elixpo.com
NEXT_PUBLIC_API_URL=https://accounts.elixpo.com/api

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Development: use JWT_SECRET (min 32 chars)
JWT_SECRET=replace-with-a-32-char-or-longer-random-string

# Production: use EdDSA key pair (generate with: npx tsx scripts/generate-keys.ts)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

JWT_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_DAYS=30

# ─── Cloudflare D1 ────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DATABASE_ID=f7455042-ed14-466a-9461-5fd36f628746
D1_DATABASE_NAME=elixpo_auth

# ─── OAuth Providers ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# ─── Email — Zoho SMTP ────────────────────────────────────────────────────────
# Production: smtp.zoho.com:587 (STARTTLS) or smtp.zoho.com:465 (SSL)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_FROM_EMAIL=accounts@elixpo.com
SMTP_FROM_NAME=Elixpo Accounts
SMTP_PASS=

# Email token settings
EMAIL_VERIFICATION_OTP_LENGTH=6
EMAIL_VERIFICATION_OTP_EXPIRY_MINUTES=10
EMAIL_VERIFICATION_LINK_EXPIRY_HOURS=24
VERIFICATION_TOKEN_LENGTH=64

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ALLOWED_ORIGINS=https://accounts.elixpo.com,https://elixpo.com

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Admin Seed (used by scripts/seed-admin.ts) ───────────────────────────────
ADMIN_EMAIL=ayushman@elixpo.com
ADMIN_PASSWORD=

# ─── Grafana (docker-compose only) ───────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_DOMAIN=accounts.elixpo.com
GRAFANA_ROOT_URL=https://accounts.elixpo.com/grafana
